{
	"schemaVersion": 1,
	"id": "legacy-bugs",
	"version": "${version}",
	"name": "Legacy Bugs",
	"description": "A research-based Fabric mod that restores historical Minecraft bugs as accurately as possible.",
	"authors": [
		"Nazar Azhar"
	],
	"contact": {
		"sources": "https://github.com/NazarAzhar/Legacy-Bugs"
	},
	"license": "GPL-3.0-only",
	"icon": "assets/legacy-bugs/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.nazarazhar.legacybugs.LegacyBugs"
		],
		"client": [
			"com.nazarazhar.legacybugs.client.LegacyBugsClient"
		]
	},
	"mixins": [
		"legacy-bugs.mixins.json",
		{
			"config": "legacy-bugs.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": ">=26.1.2 <26.3-",
		"java": ">=25",
		"fabric-api": "*"
	}
}